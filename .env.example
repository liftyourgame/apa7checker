# Copy this file to .env and fill in your values before running docker compose.

# ── Required ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional (defaults shown) ────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
MAX_UPLOAD_SIZE_MB=50

# Port the frontend nginx container binds to on the host machine
FRONTEND_PORT=80
